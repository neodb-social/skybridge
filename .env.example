# Copy to .env and edit: cp .env.example .env
# All settings are optional; see README "Configuration".

# Public host of this relay — the single source of identity for actor ids,
# webfinger, object URLs. REQUIRED for anything beyond local testing.
SKYBRIDGE_DOMAIN=bridge.example.social

# URL scheme: https by default (http when SKYBRIDGE_DOMAIN is localhost).
#SKYBRIDGE_SCHEME=https

# Folder for all mutable state (SQLite DB + relay key), default ./data.
# Under docker compose this is the HOST folder bind-mounted into the
# container (inside the container the data dir is always /data).
#SKYBRIDGE_DATA=./data

# Jetstream WebSocket endpoint (defaults to the public jetstream2 us-east).
#SKYBRIDGE_JETSTREAM=wss://jetstream2.us-east.bsky.network/subscribe

# Relay actor signing key. Explicit PEM wins; otherwise it is minted into
# SKYBRIDGE_DATA/relay_key.pem on first use. Keep it safe: losing it changes
# the relay's AP identity.
#SKYBRIDGE_RELAY_KEY=

# Set to 1 to ingest live popfeed activity inside `serve` (recommended for a
# real deployment; unset = serve existing data only).
SKYBRIDGE_INGEST=1

# Log level (DEBUG, INFO, WARNING, ...).
#SKYBRIDGE_LOG=INFO
